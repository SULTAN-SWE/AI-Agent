FROM node:24-alpine AS base
RUN npm install -g pnpm
WORKDIR /app

FROM base AS deps
COPY pnpm-workspace.yaml package.json ./
COPY lib/api-client-react/package.json ./lib/api-client-react/
COPY lib/api-zod/package.json ./lib/api-zod/
COPY lib/api-spec/package.json ./lib/api-spec/
COPY artifacts/enterprise-platform/package.json ./artifacts/enterprise-platform/
RUN pnpm install --ignore-scripts --frozen-lockfile

FROM deps AS build
COPY lib/ ./lib/
COPY artifacts/enterprise-platform/ ./artifacts/enterprise-platform/
COPY tsconfig.base.json tsconfig.json ./
ARG BASE_PATH=/
ENV BASE_PATH=$BASE_PATH
RUN pnpm run typecheck:libs
RUN PORT=3000 BASE_PATH=$BASE_PATH pnpm --filter @workspace/enterprise-platform run build

FROM nginx:alpine AS runner
COPY --from=build /app/artifacts/enterprise-platform/dist/public /usr/share/nginx/html
COPY nginx-spa.conf /etc/nginx/conf.d/default.conf
EXPOSE 3000
